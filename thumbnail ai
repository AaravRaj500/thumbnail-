<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>ThumbAI — Free Thumbnail Generator</title>
<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;600&display=swap" rel="stylesheet" />
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --bg: #080b10;
    --surface: #0e1420;
    --surface2: #151d2e;
    --border: #1e2d45;
    --accent: #00e5ff;
    --accent2: #7c3aed;
    --accent-glow: rgba(0, 229, 255, 0.12);
    --text: #e2eaf5;
    --muted: #5a7090;
    --danger: #ff4d6d;
    --success: #00e5a0;
    --font: 'Space Grotesk', sans-serif;
    --mono: 'JetBrains Mono', monospace;
  }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: var(--font);
    min-height: 100vh;
    overflow-x: hidden;
  }

  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background-image:
      linear-gradient(rgba(0,229,255,0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(0,229,255,0.03) 1px, transparent 1px);
    background-size: 40px 40px;
    pointer-events: none;
    z-index: 0;
  }

  .orb {
    position: fixed;
    border-radius: 50%;
    filter: blur(90px);
    pointer-events: none;
    z-index: 0;
    opacity: 0.3;
  }
  .orb-1 { width: 420px; height: 420px; background: #00e5ff20; top: -120px; left: -120px; animation: drift1 14s ease-in-out infinite; }
  .orb-2 { width: 320px; height: 320px; background: #7c3aed20; bottom: -100px; right: -100px; animation: drift2 17s ease-in-out infinite; }
  @keyframes drift1 { 0%,100%{transform:translate(0,0)} 50%{transform:translate(50px,35px)} }
  @keyframes drift2 { 0%,100%{transform:translate(0,0)} 50%{transform:translate(-35px,-50px)} }

  .wrap {
    position: relative;
    z-index: 1;
    max-width: 860px;
    margin: 0 auto;
    padding: 0 20px 100px;
  }

  header {
    padding: 44px 0 52px;
    text-align: center;
  }

  .free-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: rgba(0,229,160,0.1);
    border: 1px solid rgba(0,229,160,0.3);
    border-radius: 100px;
    padding: 6px 16px;
    font-family: var(--mono);
    font-size: 11px;
    color: var(--success);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: 22px;
  }
  .free-badge::before { content: '✦'; }

  h1 {
    font-size: clamp(2rem, 6vw, 3.8rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.08;
    background: linear-gradient(135deg, #ffffff 25%, var(--accent) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: 16px;
  }

  .subtitle {
    color: var(--muted);
    font-size: 1rem;
    max-width: 500px;
    margin: 0 auto;
    line-height: 1.65;
  }
  .subtitle strong { color: var(--success); }

  /* Steps */
  .step-label {
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 18px;
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .step-label::before { content: ''; width: 24px; height: 1px; background: var(--accent); display: inline-block; }

  .card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 28px 32px;
    margin-bottom: 16px;
  }

  /* Upload */
  .upload-zone {
    border: 2px dashed var(--border);
    border-radius: 12px;
    padding: 44px 24px;
    text-align: center;
    cursor: pointer;
    transition: all 0.25s;
    position: relative;
    background: var(--bg);
  }
  .upload-zone:hover, .upload-zone.drag-over {
    border-color: var(--accent);
    background: var(--accent-glow);
  }
  .upload-zone input {
    position: absolute;
    inset: 0;
    opacity: 0;
    cursor: pointer;
    width: 100%;
    height: 100%;
  }
  .upload-icon { font-size: 3rem; display: block; margin-bottom: 12px; }
  .upload-title { font-size: 1rem; font-weight: 600; margin-bottom: 6px; }
  .upload-sub { font-size: 13px; color: var(--muted); }
  .upload-sub em { color: var(--accent); font-style: normal; }

  #video-preview-wrap { display: none; margin-top: 18px; }
  #video-preview {
    width: 100%;
    max-height: 300px;
    border-radius: 10px;
    object-fit: contain;
    background: #000;
    border: 1px solid var(--border);
  }
  .video-meta {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-top: 10px;
    padding: 10px 14px;
    background: var(--surface2);
    border-radius: 8px;
    font-size: 13px;
    color: var(--muted);
  }
  .video-meta strong { color: var(--text); font-size: 13px; }
  .clear-btn {
    margin-left: auto;
    background: transparent;
    border: none;
    color: var(--muted);
    cursor: pointer;
    font-size: 18px;
    line-height: 1;
    transition: color 0.2s;
    padding: 0 4px;
  }
  .clear-btn:hover { color: var(--danger); }

  #frame-canvas { display: none; }

  /* Form elements */
  label {
    display: block;
    font-size: 13px;
    color: var(--muted);
    margin-bottom: 8px;
    font-weight: 500;
  }
  textarea, input[type="text"] {
    width: 100%;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 10px;
    color: var(--text);
    font-family: var(--font);
    font-size: 14px;
    padding: 13px 16px;
    outline: none;
    transition: border-color 0.2s;
    resize: vertical;
  }
  textarea:focus, input[type="text"]:focus { border-color: var(--accent); }
  textarea::placeholder, input[type="text"]::placeholder { color: var(--muted); }

  /* Style grid */
  .style-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(130px, 1fr));
    gap: 10px;
  }
  .style-opt {
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 14px 10px;
    cursor: pointer;
    text-align: center;
    transition: all 0.2s;
    background: var(--bg);
    user-select: none;
  }
  .style-opt:hover { border-color: var(--accent); background: var(--accent-glow); }
  .style-opt.selected { border-color: var(--accent); background: var(--accent-glow); box-shadow: 0 0 0 1px var(--accent); }
  .style-opt input { display: none; }
  .s-icon { font-size: 1.7rem; display: block; margin-bottom: 6px; }
  .s-name { font-size: 13px; font-weight: 600; color: var(--text); display: block; }
  .s-desc { font-size: 11px; color: var(--muted); display: block; margin-top: 2px; }

  /* Mood */
  .mood-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }
  .mood-chip {
    border: 1px solid var(--border);
    border-radius: 100px;
    padding: 6px 14px;
    font-size: 12px;
    cursor: pointer;
    transition: all 0.2s;
    background: var(--bg);
    color: var(--muted);
    user-select: none;
  }
  .mood-chip:hover { border-color: var(--accent2); color: var(--text); }
  .mood-chip.selected { border-color: var(--accent2); background: rgba(124,58,237,0.15); color: #c4b5fd; }

  /* Generate button */
  .generate-btn {
    width: 100%;
    padding: 20px;
    border: none;
    border-radius: 14px;
    background: linear-gradient(135deg, var(--accent) 0%, #0096b7 100%);
    color: #000;
    font-family: var(--font);
    font-size: 17px;
    font-weight: 700;
    cursor: pointer;
    letter-spacing: 0.01em;
    transition: all 0.25s;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    margin-top: 8px;
  }
  .generate-btn:disabled { opacity: 0.45; cursor: not-allowed; transform: none !important; box-shadow: none !important; }
  .generate-btn:not(:disabled):hover { transform: translateY(-2px); box-shadow: 0 10px 40px rgba(0,229,255,0.28); }
  .spinner {
    width: 20px; height: 20px;
    border: 2.5px solid rgba(0,0,0,0.25);
    border-top-color: #000;
    border-radius: 50%;
    animation: spin 0.7s linear infinite;
    display: none;
  }
  .generate-btn.loading .spinner { display: block; }
  @keyframes spin { to { transform: rotate(360deg); } }

  /* Progress */
  #progress-wrap { display: none; margin-top: 16px; }
  .progress-bar-track {
    height: 3px;
    background: var(--border);
    border-radius: 100px;
    overflow: hidden;
    margin-bottom: 12px;
  }
  .progress-bar-fill {
    height: 100%;
    background: linear-gradient(90deg, var(--accent), var(--accent2));
    border-radius: 100px;
    transition: width 0.5s ease;
    width: 0%;
  }
  .log-box {
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 14px 16px;
    font-family: var(--mono);
    font-size: 12px;
    line-height: 2;
    color: var(--muted);
    max-height: 140px;
    overflow-y: auto;
  }
  .log-line { display: block; }
  .log-line.active { color: var(--accent); }
  .log-line.done { color: var(--success); }
  .log-line.err { color: var(--danger); }

  /* Results */
  #results { display: none; margin-top: 20px; }

  .result-image-wrap {
    width: 100%;
    aspect-ratio: 16/9;
    border-radius: 12px;
    overflow: hidden;
    background: #000;
    border: 1px solid var(--border);
    position: relative;
    margin-bottom: 16px;
  }
  #output-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: none;
  }
  .img-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 10px;
    color: var(--muted);
    font-size: 14px;
  }

  .info-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
    margin-bottom: 12px;
  }
  @media(max-width:560px) { .info-grid { grid-template-columns: 1fr; } }

  .info-card {
    background: var(--surface2);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 16px;
  }
  .info-card-label {
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 8px;
    display: block;
  }
  .info-card-text { font-size: 13px; line-height: 1.65; color: var(--text); }

  .prompt-display {
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 14px 16px;
    font-family: var(--mono);
    font-size: 12px;
    color: #8ab4d4;
    line-height: 1.75;
    position: relative;
    word-break: break-word;
    margin-bottom: 12px;
  }
  .copy-btn {
    position: absolute;
    top: 10px; right: 10px;
    background: var(--surface);
    border: 1px solid var(--border);
    color: var(--muted);
    font-size: 11px;
    padding: 4px 10px;
    border-radius: 6px;
    cursor: pointer;
    font-family: var(--font);
    transition: all 0.2s;
  }
  .copy-btn:hover { border-color: var(--accent); color: var(--accent); }

  .action-row {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
  }
  .dl-btn, .regen-btn {
    flex: 1;
    padding: 13px;
    border-radius: 10px;
    font-family: var(--font);
    font-size: 14px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 7px;
    min-width: 140px;
  }
  .dl-btn {
    background: var(--accent);
    color: #000;
    border: none;
  }
  .dl-btn:hover { opacity: 0.85; }
  .regen-btn {
    background: transparent;
    border: 1px solid var(--border);
    color: var(--muted);
  }
  .regen-btn:hover { border-color: var(--accent); color: var(--accent); }

  .alt-links {
    margin-top: 10px;
    font-size: 12px;
    color: var(--muted);
    line-height: 2;
  }
  .alt-links a { color: var(--accent); text-decoration: none; }
  .alt-links a:hover { text-decoration: underline; }

  /* Toast */
  #toast {
    position: fixed;
    bottom: 24px;
    left: 50%;
    transform: translateX(-50%) translateY(80px);
    font-size: 13px;
    font-weight: 600;
    padding: 12px 24px;
    border-radius: 100px;
    z-index: 200;
    transition: transform 0.3s ease;
    white-space: nowrap;
    pointer-events: none;
  }
  #toast.show { transform: translateX(-50%) translateY(0); }
</style>
</head>
<body>
<div class="orb orb-1"></div>
<div class="orb orb-2"></div>

<div class="wrap">
  <header>
    <div class="free-badge">100% Free — No API Key Needed</div>
    <h1>Turn your video into<br>a killer thumbnail</h1>
    <p class="subtitle">Upload a video, describe it briefly, and AI generates a <strong>professional thumbnail</strong> — completely free, no sign-up.</p>
  </header>

  <!-- Step 1: Upload -->
  <div class="card">
    <div class="step-label">01 — Upload Your Video</div>
    <div class="upload-zone" id="upload-zone">
      <input type="file" id="video-input" accept="video/*" />
      <span class="upload-icon">🎬</span>
      <div class="upload-title">Drop video here or click to browse</div>
      <div class="upload-sub">MP4, MOV, AVI, WebM — <em>stays on your device, never uploaded</em></div>
    </div>
    <div id="video-preview-wrap">
      <video id="video-preview" controls playsinline></video>
      <div class="video-meta">
        <span>🎞</span>
        <strong id="video-name">video.mp4</strong>
        <button class="clear-btn" onclick="clearVideo()" title="Remove">✕</button>
      </div>
    </div>
    <canvas id="frame-canvas"></canvas>
  </div>

  <!-- Step 2: Describe -->
  <div class="card">
    <div class="step-label">02 — Describe Your Video</div>
    <label>What is your video about? <span style="color:var(--danger)">*</span></label>
    <textarea id="description" rows="3" placeholder="E.g. 'Valorant ranked gameplay highlights with crazy clutch moments', 'Tutorial on making biryani at home', 'Unboxing and reviewing the new iPhone 16'..."></textarea>
  </div>

  <!-- Step 3: Style -->
  <div class="card">
    <div class="step-label">03 — Pick a Style</div>
    <div class="style-grid">
      <label class="style-opt selected">
        <input type="radio" name="style" value="cinematic" checked />
        <span class="s-icon">🎥</span>
        <span class="s-name">Cinematic</span>
        <span class="s-desc">Epic & dramatic</span>
      </label>
      <label class="style-opt">
        <input type="radio" name="style" value="realistic" />
        <span class="s-icon">📸</span>
        <span class="s-name">Realistic</span>
        <span class="s-desc">Natural photo</span>
      </label>
      <label class="style-opt">
        <input type="radio" name="style" value="illustrated" />
        <span class="s-icon">🎨</span>
        <span class="s-name">Illustrated</span>
        <span class="s-desc">Artistic & bold</span>
      </label>
      <label class="style-opt">
        <input type="radio" name="style" value="neon" />
        <span class="s-icon">⚡</span>
        <span class="s-name">Neon Cyber</span>
        <span class="s-desc">Dark & glowing</span>
      </label>
      <label class="style-opt">
        <input type="radio" name="style" value="anime" />
        <span class="s-icon">✨</span>
        <span class="s-name">Anime</span>
        <span class="s-desc">Stylized art</span>
      </label>
    </div>
  </div>

  <!-- Step 4: Mood -->
  <div class="card">
    <div class="step-label">04 — Select Mood <span style="color:var(--muted);font-size:10px;margin-left:4px;">(pick any)</span></div>
    <div class="mood-grid" id="mood-grid">
      <span class="mood-chip" data-mood="intense">🔥 Intense</span>
      <span class="mood-chip" data-mood="funny">😂 Funny</span>
      <span class="mood-chip" data-mood="epic">💥 Epic</span>
      <span class="mood-chip" data-mood="satisfying">😌 Satisfying</span>
      <span class="mood-chip" data-mood="shocking">😱 Shocking</span>
      <span class="mood-chip" data-mood="mysterious">🌑 Mysterious</span>
      <span class="mood-chip" data-mood="motivational">💪 Motivational</span>
      <span class="mood-chip" data-mood="chill">🌊 Chill</span>
    </div>
  </div>

  <!-- Generate -->
  <button class="generate-btn" id="generate-btn" onclick="generate()">
    <div class="spinner"></div>
    <span id="btn-text">✦ Generate Thumbnail — Free</span>
  </button>

  <!-- Progress -->
  <div id="progress-wrap">
    <div class="progress-bar-track"><div class="progress-bar-fill" id="progress-bar"></div></div>
    <div class="log-box" id="log-box"></div>
  </div>

  <!-- Results -->
  <div id="results">
    <div class="card">
      <div class="step-label">Generated Thumbnail</div>

      <div class="result-image-wrap">
        <div class="img-placeholder" id="img-placeholder">
          <span style="font-size:2.5rem">🖼️</span>
          <span>Your thumbnail will appear here</span>
        </div>
        <img id="output-image" alt="Generated thumbnail" />
      </div>

      <div class="info-grid">
        <div class="info-card">
          <span class="info-card-label">Concept Used</span>
          <div class="info-card-text" id="concept-text">—</div>
        </div>
        <div class="info-card">
          <span class="info-card-label">Style Applied</span>
          <div class="info-card-text" id="style-text">—</div>
        </div>
      </div>

      <div style="margin-bottom:8px;">
        <span class="info-card-label" style="font-family:var(--mono);font-size:10px;letter-spacing:0.1em;text-transform:uppercase;color:var(--accent);display:block;margin-bottom:8px;">Full Prompt Used</span>
        <div class="prompt-display" id="prompt-display">
          —
          <button class="copy-btn" onclick="copyPrompt()">Copy</button>
        </div>
      </div>

      <div class="action-row">
        <button class="dl-btn" onclick="downloadThumb()">⬇ Download Thumbnail</button>
        <button class="regen-btn" onclick="regenerate()">↻ Try Different Seed</button>
      </div>

      <div class="alt-links">
        💡 Want more control? Paste the prompt above into:
        <a href="https://ideogram.ai" target="_blank">Ideogram.ai</a> ·
        <a href="https://leonardo.ai" target="_blank">Leonardo.ai</a> ·
        <a href="https://app.canva.com" target="_blank">Canva AI</a>
      </div>
    </div>
  </div>
</div>

<div id="toast"></div>

<script>
// ── Style selector ─────────────────────────────────────────────────────────
document.querySelectorAll('.style-opt').forEach(opt => {
  opt.addEventListener('click', () => {
    document.querySelectorAll('.style-opt').forEach(o => o.classList.remove('selected'));
    opt.classList.add('selected');
  });
});

// ── Mood chips ─────────────────────────────────────────────────────────────
document.querySelectorAll('.mood-chip').forEach(chip => {
  chip.addEventListener('click', () => chip.classList.toggle('selected'));
});

function getSelectedMoods() {
  return [...document.querySelectorAll('.mood-chip.selected')].map(c => c.dataset.mood);
}

// ── Video upload ───────────────────────────────────────────────────────────
const videoInput = document.getElementById('video-input');
const videoPreview = document.getElementById('video-preview');
const uploadZone = document.getElementById('upload-zone');

videoInput.addEventListener('change', e => { if (e.target.files[0]) loadVideo(e.target.files[0]); });

uploadZone.addEventListener('dragover', e => { e.preventDefault(); uploadZone.classList.add('drag-over'); });
uploadZone.addEventListener('dragleave', () => uploadZone.classList.remove('drag-over'));
uploadZone.addEventListener('drop', e => {
  e.preventDefault();
  uploadZone.classList.remove('drag-over');
  const f = e.dataTransfer.files[0];
  if (f && f.type.startsWith('video/')) loadVideo(f);
});

function loadVideo(file) {
  videoPreview.src = URL.createObjectURL(file);
  document.getElementById('video-name').textContent = file.name;
  document.getElementById('video-preview-wrap').style.display = 'block';
  uploadZone.style.display = 'none';
}

function clearVideo() {
  videoPreview.src = '';
  videoInput.value = '';
  document.getElementById('video-preview-wrap').style.display = 'none';
  uploadZone.style.display = 'block';
}

// ── Frame extractor ────────────────────────────────────────────────────────
function extractFrame() {
  return new Promise((resolve) => {
    const canvas = document.getElementById('frame-canvas');
    const ctx = canvas.getContext('2d');
    const v = videoPreview;
    const t = isFinite(v.duration) ? Math.min(v.duration * 0.3, v.duration - 0.1) : 0;
    v.currentTime = t >= 0 ? t : 0;
    v.onseeked = () => {
      canvas.width = v.videoWidth || 1280;
      canvas.height = v.videoHeight || 720;
      ctx.drawImage(v, 0, 0, canvas.width, canvas.height);
      resolve(canvas.toDataURL('image/jpeg', 0.8));
    };
    // Fallback if no video loaded
    setTimeout(() => resolve(null), 3000);
  });
}

// ── Prompt builder ─────────────────────────────────────────────────────────
const stylePrompts = {
  cinematic: 'cinematic lighting, dramatic shadows, movie poster composition, anamorphic lens flare, color graded, epic atmosphere, 8k ultra detailed',
  realistic: 'ultra realistic photography, DSLR photo, natural lighting, sharp focus, high resolution, professional shot, photorealistic',
  illustrated: 'vibrant digital illustration, bold graphic design, vivid colors, high contrast, painterly texture, dynamic composition, concept art style',
  neon: 'neon cyberpunk aesthetic, glowing neon lights, dark background, electric cyan and purple colors, futuristic, digital glow, synthwave atmosphere',
  anime: 'anime style, detailed anime art, vibrant colors, dynamic pose, high quality anime illustration, manga inspired, expressive'
};

const moodPrompts = {
  intense: 'intense dramatic energy, high tension',
  funny: 'comedic exaggerated expression, humorous',
  epic: 'epic monumental scale, grand spectacle',
  satisfying: 'clean satisfying composition, pleasing aesthetics',
  shocking: 'shocking surprising moment, dramatic reveal',
  mysterious: 'mysterious dark atmosphere, intriguing shadows',
  motivational: 'powerful motivational energy, inspiring heroic',
  chill: 'calm relaxed atmosphere, peaceful vibes'
};

function buildPrompt(description, style, moods) {
  const styleStr = stylePrompts[style] || stylePrompts.cinematic;
  const moodStr = moods.length > 0 ? moods.map(m => moodPrompts[m]).join(', ') + ', ' : '';
  return `YouTube thumbnail for: ${description}. ${moodStr}${styleStr}, striking composition that stops the scroll, bold and eye-catching, professional YouTube thumbnail, 16:9 aspect ratio, no text overlays, high quality`.trim();
}

// ── Progress helpers ───────────────────────────────────────────────────────
let logLines = [];

function resetLog() {
  logLines = [];
  document.getElementById('log-box').innerHTML = '';
  setProgress(0);
}

function log(msg, state = 'active') {
  const box = document.getElementById('log-box');
  const el = document.createElement('span');
  el.className = `log-line ${state}`;
  const icons = { active: '◈', done: '✓', err: '✕' };
  el.textContent = `${icons[state]}  ${msg}`;
  box.appendChild(el);
  box.appendChild(document.createElement('br'));
  box.scrollTop = box.scrollHeight;
  logLines.push(el);
  return el;
}

function markDone(el) { el.className = 'log-line done'; }
function markErr(el) { el.className = 'log-line err'; }

function setProgress(pct) {
  document.getElementById('progress-bar').style.width = pct + '%';
}

// ── Toast ──────────────────────────────────────────────────────────────────
function toast(msg, success = false) {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.style.background = success ? 'var(--success)' : 'var(--danger)';
  t.style.color = success ? '#000' : '#fff';
  t.classList.add('show');
  setTimeout(() => t.classList.remove('show'), 3000);
}

// ── Current prompt storage ─────────────────────────────────────────────────
let currentPrompt = '';
let currentImageUrl = '';

// ── Main generate ──────────────────────────────────────────────────────────
async function generate(customSeed = null) {
  const description = document.getElementById('description').value.trim();
  if (!description) { toast('Please describe your video first!'); document.getElementById('description').focus(); return; }

  const style = document.querySelector('input[name="style"]:checked').value;
  const moods = getSelectedMoods();

  // Build prompt
  currentPrompt = buildPrompt(description, style, moods);

  const btn = document.getElementById('generate-btn');
  btn.disabled = true;
  btn.classList.add('loading');
  document.getElementById('btn-text').textContent = 'Generating…';

  // Show progress
  document.getElementById('progress-wrap').style.display = 'block';
  resetLog();

  try {
    // Step 1
    const l1 = log('Building AI prompt from your description…');
    await delay(400);
    setProgress(20);
    markDone(l1);

    // Step 2: Extract frame if video loaded
    let frameDataUrl = null;
    if (videoPreview.src && videoPreview.src !== window.location.href) {
      const l2 = log('Extracting frame from video…');
      frameDataUrl = await extractFrame();
      markDone(l2);
      setProgress(40);
    }

    // Step 3: Generate image via Pollinations
    const l3 = log('Sending to Pollinations AI (free image gen)…');
    setProgress(55);

    const seed = customSeed || Math.floor(Math.random() * 999999);
    const imageUrl = await generateWithPollinations(currentPrompt, seed);

    markDone(l3);
    setProgress(85);

    // Step 4: Load image
    const l4 = log('Loading your thumbnail…');
    await loadImage(imageUrl);
    markDone(l4);
    setProgress(100);

    // Show results
    currentImageUrl = imageUrl;
    const img = document.getElementById('output-image');
    img.src = imageUrl;
    img.style.display = 'block';
    document.getElementById('img-placeholder').style.display = 'none';

    document.getElementById('concept-text').textContent = `${description.slice(0, 100)}${description.length > 100 ? '…' : ''}`;
    document.getElementById('style-text').textContent = `${style.charAt(0).toUpperCase() + style.slice(1)}${moods.length ? ' · ' + moods.join(', ') : ''}`;
    document.getElementById('prompt-display').innerHTML = currentPrompt + '<button class="copy-btn" onclick="copyPrompt()">Copy</button>';

    log('Thumbnail ready! ✦', 'done');
    document.getElementById('results').style.display = 'block';
    document.getElementById('results').scrollIntoView({ behavior: 'smooth', block: 'start' });

  } catch (err) {
    log(`Failed: ${err.message}`, 'err');
    log('Try again or use the prompt in Ideogram.ai', 'err');
    toast('Generation failed — try again');
    console.error(err);
  } finally {
    btn.disabled = false;
    btn.classList.remove('loading');
    document.getElementById('btn-text').textContent = '✦ Generate Thumbnail — Free';
  }
}

// ── Pollinations API (completely free, no key) ─────────────────────────────
async function generateWithPollinations(prompt, seed) {
  const encoded = encodeURIComponent(prompt);
  // Pollinations free image API — no auth required
  const url = `https://image.pollinations.ai/prompt/${encoded}?width=1280&height=720&seed=${seed}&model=flux&nologo=true&enhance=true`;
  return url; // Pollinations returns the image directly at this URL
}

// ── Load image with timeout ────────────────────────────────────────────────
function loadImage(url) {
  return new Promise((resolve, reject) => {
    const img = new Image();
    img.crossOrigin = 'anonymous';
    img.onload = resolve;
    img.onerror = () => reject(new Error('Image failed to load from Pollinations'));
    img.src = url;
    setTimeout(() => reject(new Error('Timeout — Pollinations took too long')), 60000);
  });
}

// ── Regenerate with new seed ───────────────────────────────────────────────
function regenerate() {
  document.getElementById('output-image').style.display = 'none';
  document.getElementById('img-placeholder').style.display = 'flex';
  document.getElementById('results').style.display = 'none';
  generate(Math.floor(Math.random() * 999999));
}

// ── Download ───────────────────────────────────────────────────────────────
async function downloadThumb() {
  if (!currentImageUrl) return;
  try {
    const response = await fetch(currentImageUrl);
    const blob = await response.blob();
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = 'thumbnail.jpg';
    a.click();
    URL.revokeObjectURL(url);
  } catch {
    // Fallback: open in new tab
    window.open(currentImageUrl, '_blank');
  }
}

// ── Copy prompt ────────────────────────────────────────────────────────────
function copyPrompt() {
  navigator.clipboard.writeText(currentPrompt).then(() => toast('Prompt copied!', true));
}

// ── Util ───────────────────────────────────────────────────────────────────
function delay(ms) { return new Promise(r => setTimeout(r, ms)); }
